# ===== Painel admin =====
# Senha de acesso ao painel (/admin). Troque por uma senha forte.
ADMIN_PASSWORD=troque-esta-senha

# Segredo para assinar a sessão do admin. Gere um valor aleatório longo.
# Ex.: rode no terminal -> node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cole-aqui-um-valor-aleatorio-longo

# ===== Armazenamento de imagens/dados (Vercel Blob) =====
# Criado automaticamente ao conectar um Blob Store no projeto da Vercel.
# Em desenvolvimento local pode deixar vazio: o site usa arquivos locais.
BLOB_READ_WRITE_TOKEN=
