# ===== Painel admin =====
# Usuário e senha de acesso ao painel (/admin). Troque por credenciais fortes.
ADMIN_USER=troque-o-usuario
ADMIN_PASSWORD=troque-esta-senha

# Segredo para assinar a sessão do admin. Gere um valor aleatório longo.
# Ex.: rode no terminal -> node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cole-aqui-um-valor-aleatorio-longo

# ===== Captura de leads por e-mail (Resend) =====
# Chave de API criada em https://resend.com (Settings -> API Keys).
RESEND_API_KEY=
# Remetente. Sem domínio verificado na Resend, use o padrão de teste
# "Monsueto Turismo <onboarding@resend.dev>". Com o domínio verificado,
# troque por algo como "Monsueto Turismo <leads@monsueto.com.br>".
LEAD_FROM=
# Destinatário dos leads (padrão: e-mail da empresa em lib/config.ts).
LEAD_TO=

# ===== Armazenamento de imagens/dados (Vercel Blob) =====
# Criado automaticamente ao conectar um Blob Store no projeto da Vercel.
# Em desenvolvimento local pode deixar vazio: o site usa arquivos locais.
BLOB_READ_WRITE_TOKEN=
